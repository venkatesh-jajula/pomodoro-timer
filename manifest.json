{
    "manifest_version": 3,
    "name": "Pomodoro Timer",
    "version": "1.0",
    "description": "Boost productivity with a Pomodoro timer. Set custom durations (1-60 min), manage tasks, and get notifications when your session ends. Stay focused!",
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    "permissions": [
        "storage",
        "notifications",
        "alarms"
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": "icon.png",
        "default_title": "Pomodoro Timer"
    },
    "options_page": "options/options.html",
    "background": {
        "service_worker": "background.js"
    }
}